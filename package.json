{
  "name": "openmeet",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm --filter @openmeet/shared build && pnpm --filter @openmeet/client build && pnpm --filter @openmeet/server build && pnpm --filter openmeet-terminal build",
    "clean": "pnpm -r clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@roamhq/wrtc"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  }
}
