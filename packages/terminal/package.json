{
  "name": "openmeet-terminal",
  "version": "0.1.1",
  "description": "Join OpenMeet video rooms from the terminal — audio chat and text messaging via WebRTC",
  "type": "module",
  "bin": {
    "openmeet": "./dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "start": "tsx src/index.tsx",
    "build": "node build.mjs",
    "build:tsc": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "node build.mjs"
  },
  "keywords": [
    "webrtc",
    "video-conferencing",
    "terminal",
    "cli",
    "audio-chat",
    "openmeet"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.8.0",
    "ws": "^8.18.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "react": "^18.3.1",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@openmeet/shared": "workspace:*",
    "@types/ws": "^8.5.0",
    "@types/react": "^18.3.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
