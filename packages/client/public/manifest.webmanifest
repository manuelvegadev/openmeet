{
  "name": "OpenMeet",
  "short_name": "OpenMeet",
  "description": "Lightweight video conferencing — create or join rooms to video chat, share screens, and send messages",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0a0a0a",
